{
  "name": "tinda",
  "version": "1.0.0",
  "description": "A Point of Sales System for Toto Store in Partial Fulfillment for System Analysis Design",
  "author": "The TiNDA Team",
  "contributors": [
    "Sean Agapito",
    "Mico Gonzales",
    "Elsoh Nicolas",
    "Carlos Pacino",
    "Jerome Teodoro"
  ],
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.TiNDA.app",
    "productName": "TiNDA",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "frontend/**",
      "backend/**",
      "database/**",
      "package.json",
      "node_modules/**"
    ]
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
